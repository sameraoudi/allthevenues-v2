# Environment-specific secrets — created per environment, never committed.
config/config.php

# Logs
*.log

# Legacy DB dumps — never commit (keep them outside the repo, e.g. ~/atv-legacy/).
*.sql.gz
sameraou_atv*.sql
!db/[0-9]*.sql

# Uploaded files — keep the directory scaffolding, ignore contents.
uploads/*
!uploads/.htaccess
!uploads/.gitkeep

# Runtime data (rate-limit counters, mail logs, session files) — keep
# scaffolding, ignore contents.
storage/ratelimit/*
storage/mail/*
storage/sessions/*
!storage/.htaccess
!storage/.gitkeep
!storage/ratelimit/.gitkeep
!storage/mail/.gitkeep
!storage/sessions/.htaccess
!storage/sessions/.gitkeep

# OS cruft
.DS_Store
