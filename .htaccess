# All The Venues — root .htaccess (versioned security config).
# Deploy target: staging.allthevenues.com, docroot /home1/sameraou/atv-staging
# (outside public_html — no inherited CSP). LiteSpeed honors Apache .htaccess.
#
# NO php_flag / php_value directives here — on this host they crash the site.

RewriteEngine On

# === Force HTTPS (301), excluding localhost dev ===
RewriteCond %{HTTP_HOST} !^localhost [NC]
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# === Security headers ===
<IfModule mod_headers.c>
    # HSTS — unconditional (staging is HTTPS-only; HTTP is redirected above).
    Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"

    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"

    # Content-Security-Policy — TIGHT. Bootstrap is self-hosted (no CDN).
    # External origins allowed:
    #   GoatCounter analytics — script gc.zgo.at, connect allthevenues.goatcounter.com
    #   Cloudflare Turnstile (enquiry anti-bot) — script + frame + connect
    #     challenges.cloudflare.com
    #   Google Maps embed (venue detail map iframe) — frame www.google.com
    #     (stored map_embed uses https://www.google.com/maps/embed). KEEP THIS —
    #     removing it blanks the venue-detail map.
    # Web fonts get added here as those features land.
    # Defensive: drop any CSP inherited from a parent .htaccess (e.g. the apex
    # docroot at cutover) so exactly ONE policy — ours below — is ever sent.
    Header always unset Content-Security-Policy
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' https://gc.zgo.at https://challenges.cloudflare.com; style-src 'self'; img-src 'self' data: https://allthevenues.goatcounter.com; font-src 'self'; connect-src 'self' https://allthevenues.goatcounter.com https://challenges.cloudflare.com; frame-src https://challenges.cloudflare.com https://www.google.com; frame-ancestors 'self'; base-uri 'self'; form-action 'self'; object-src 'none'"
</IfModule>

# === Static-asset browser caching (Perf-1) ===
# Long-lived cache for immutable static assets ONLY (scoped by extension), so
# HTML / dynamic responses keep their default no-cache behaviour. CSS/JS carry a
# ?v=<mtime> cache-buster (asset_url()) so a deploy invalidates them; fonts/images
# rarely change and stay unversioned under the same TTL. LiteSpeed honours both
# mod_expires and the mod_headers fallback.
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css                 "access plus 1 year"
    ExpiresByType application/javascript   "access plus 1 year"
    ExpiresByType text/javascript          "access plus 1 year"
    ExpiresByType font/woff2               "access plus 1 year"
    ExpiresByType font/woff                "access plus 1 year"
    ExpiresByType image/png                "access plus 1 year"
    ExpiresByType image/jpeg               "access plus 1 year"
    ExpiresByType image/webp               "access plus 1 year"
    ExpiresByType image/svg+xml            "access plus 1 year"
    ExpiresByType image/gif                "access plus 1 year"
    ExpiresByType image/x-icon             "access plus 1 year"
    ExpiresByType image/vnd.microsoft.icon "access plus 1 year"
</IfModule>
<IfModule mod_headers.c>
    # Authoritative Cache-Control for matched static assets (adds "immutable";
    # replaces any value mod_expires set). Unmatched responses (HTML) untouched.
    <FilesMatch "\.(css|js|woff2?|png|jpe?g|webp|svg|ico|gif)$">
        Header set Cache-Control "public, max-age=31536000, immutable"
    </FilesMatch>
</IfModule>

# --- Deny web access to internal docs + markdown source (served files only;
#     PHP filesystem reads for the legal pages are unaffected) ---
RedirectMatch 403 ^/docs(/|$)
<FilesMatch "\.md$">
    Require all denied
</FilesMatch>

# === Legacy 301s (fixed paths) — U6 Phase-4 ===
# Preserve the old site's indexed URLs. The trailing "?" on each target DROPS the
# old query string. Per-record paths (venue.php?venueid=, provider.php?pid=) are
# intentionally NOT here — they fall through to index.php and 301 by legacy_id in
# lib/legacy_redirect.php.
RewriteRule ^venues\.php$     /venues?        [R=301,L]
RewriteRule ^providers\.php$  /providers?     [R=301,L]
RewriteRule ^about\.php$      /about?         [R=301,L]
RewriteRule ^legal\.php$      /terms-of-use?  [R=301,L]
RewriteRule ^help\.php$       /contact?       [R=301,L]
RewriteRule ^whydubai\.php$   /about?         [R=301,L]

# === Front-controller routing ===
# Serve real files/directories directly; route everything else to index.php.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]
RewriteRule ^ index.php [L]

# === Deny dotfiles (.htaccess, .git, .env, etc.) ===
<FilesMatch "^\.">
    Require all denied
</FilesMatch>

# === Hide sensitive file types from the web ===
<FilesMatch "\.(bak|old|orig|swp|swo|tmp|log|sql|sh|inc|yml|env|ini|dist|sample|example)$">
    Require all denied
</FilesMatch>

# === Hardening ===
Options -Indexes
ServerSignature Off
